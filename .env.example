# AI vs AI — environment configuration
# Copy to .env and edit as needed.

# Server
AIVSAI_HOST=127.0.0.1
AIVSAI_PORT=8000

# Default attacker backend (overridable per run from the UI)
# Examples:
#   Ollama:   AIVSAI_DEFAULT_ATTACKER_BASE_URL=http://localhost:11434/v1
#   OpenAI:   AIVSAI_DEFAULT_ATTACKER_BASE_URL=https://api.openai.com/v1
#   Groq:     AIVSAI_DEFAULT_ATTACKER_BASE_URL=https://api.groq.com/openai/v1
AIVSAI_DEFAULT_ATTACKER_BASE_URL=http://localhost:11434/v1
AIVSAI_DEFAULT_ATTACKER_MODEL=llama3.1:8b
AIVSAI_DEFAULT_ATTACKER_API_KEY=

# Hard caps to protect users from runaway costs / accidental DoS of target
AIVSAI_MAX_ITERATIONS=50
AIVSAI_MAX_REQUESTS_PER_SECOND=2
# Heavy local Ollama models (mixtral 8x7b, llama 70b) may need 120-300s per call
# on CPU/MPS Macs. First call after a fresh `ollama pull` is the slowest because
# the model has to be loaded into RAM.
AIVSAI_REQUEST_TIMEOUT_SECONDS=180
